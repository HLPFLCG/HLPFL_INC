{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hlpfl-inc",
  "pages_build_output_dir": ".open-next/assets",
  "compatibility_date": "2026-04-24",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "images": {
    "binding": "IMAGES"
  },
  "observability": {
    "enabled": true
  }
}
