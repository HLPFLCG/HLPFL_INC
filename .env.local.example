# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # Server-only, never expose to client

# ─── STRIPE ───────────────────────────────────────────────────────────────────
# Test keys: Dashboard → Developers → API keys
# Use sk_test_... in development, sk_live_... in production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # Created when you add the webhook endpoint

# ─── RESEND ───────────────────────────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=stays@hlpfl.org   # Must match a verified domain in Resend

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://hlpfl.org   # Used for Stripe redirect URLs
# For local dev: NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── PORTAL ───────────────────────────────────────────────────────────────────
# 32-byte hex key for PII field encryption (generate with: openssl rand -hex 32)
HLPFL_PORTAL_ENCRYPTION_KEY=your_32_byte_hex_key_here_never_commit

# Cookie domain for SSO across all hlpfl.org subdomains
# For local dev: set to "localhost" (no leading dot, no port)
NEXT_PUBLIC_PORTAL_COOKIE_DOMAIN=.hlpfl.org

# ─── ADMIN API ────────────────────────────────────────────────────────────────
# Used to authenticate admin API routes (/api/admin/*).
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=your_admin_api_key_here_never_commit

# ─── MAILCHIMP ────────────────────────────────────────────────────────────────
# Get from: Mailchimp → Account → API keys
# Leave blank to disable Mailchimp sync.
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=

# ─── TWILIO (optional — for SMS/WhatsApp escalation) ──────────────────────────
# Required for SMS escalation on dinner reservations. Leave blank to use email-only.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=    # E.164 format, e.g. +15005550006

# ─── SUPABASE STORAGE ─────────────────────────────────────────────────────────
# Create a storage bucket named "documents" in your Supabase Dashboard:
# Supabase Dashboard → Storage → New bucket → name: "documents" → private (RLS on)
# No env vars needed — the bucket name is hardcoded as "documents" in the app.

